# Normalize line endings in the repo
* text=auto

# Shell + JS/TS should be LF
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.hbs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Windows-only if any
*.bat text eol=crlf
*.cmd text eol=crlf
