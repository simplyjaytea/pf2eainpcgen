<form id="{{rootId}}" autocomplete="off">
  <section class="standard-form">
    <div class="form-group">
      <label for="{{rootId}}-prompt">Prompt</label>
      <div class="form-fields">
        <input type="text" id="{{rootId}}-prompt" name="prompt" value="{{lastPrompt}}" placeholder="e.g. cunning drow assassin with crossbow" />
      </div>
      <p class="hint">Describe the NPC concept. AI will choose exact items and abilities.</p>
    </div>

    <div class="form-group">
      <label>Level</label>
      <div class="form-fields">
        <range-picker name="level" min="1" max="25" step="1" value="{{lastLevel}}"></range-picker>
        <span data-preview-level-dc></span>
      </div>
      <p class="hint">1–25. Defaults to average party level (or player-owned PCs).</p>
    </div>

    <a data-action="toggle-advanced" style="cursor:pointer">Advanced</a>
    <section class="advanced hidden" style="margin-top:0.5rem">
      <div class="form-group">
        <label>DeepSeek API Key (override)</label>
        <div class="form-fields">
          <input type="password" name="apiKey" placeholder="sk-..." />
        </div>
        <p class="hint">If blank, uses the key saved in Client Settings.</p>
      </div>
    </section>
  </section>

  <div class="generation-progress hidden" data-generation-progress>
    <div class="progress-label" data-progress-label></div>
    <div class="progress"><div class="bar" data-progress-bar style="width: 0%;"></div></div>
  </div>
</form>
