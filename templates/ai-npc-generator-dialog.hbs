<form id="{{rootId}}" autocomplete="off">
  <div class="generator-body">
    <section class="standard-form">
      <div class="form-group">
        <label for="{{rootId}}-prompt">Prompt</label>
        <div class="form-fields">
          <input type="text" id="{{rootId}}-prompt" name="prompt" value="{{lastPrompt}}" placeholder="e.g. cunning drow assassin with crossbow" />
        </div>
        <p class="hint">Describe the NPC concept. AI will choose exact items and abilities.</p>
      </div>

      <div class="form-group level-row">
        <label>Level</label>
        <div class="form-fields">
          <range-picker name="level" min="1" max="25" step="1" value="{{lastLevel}}"></range-picker>
          <span class="level-dc" data-preview-level-dc></span>
        </div>
        <p class="hint">1–25. Defaults to average party level (or player-owned PCs).</p>
      </div>
    </section>

    <!-- Encounter Builder (UI only - no functionality yet) -->
    <section class="encounter-builder">
      <h4>{{encLabels.title}} <span class="badge">{{encLabels.coming}}</span></h4>
      <div class="enc-grid">
        <div class="enc-field">
          <label>{{encLabels.party}}</label>
          <div class="enc-value" data-enc-party-level>{{partyLevel}}</div>
        </div>
        <div class="enc-field">
          <label>{{encLabels.num}}</label>
          <input type="number" value="1" min="1" max="8" disabled />
        </div>
        <div class="enc-field">
          <label>{{encLabels.diff}}</label>
          <select disabled>
            <option>Trivial</option>
            <option>Low</option>
            <option selected>Moderate</option>
            <option>Severe</option>
            <option>Extreme</option>
          </select>
        </div>
      </div>
      <div class="enc-roles">
        <span class="role-pill">Boss</span>
        <span class="role-pill">Lieutenant</span>
        <span class="role-pill">Minions</span>
      </div>
      <button type="button" class="enc-btn" disabled>{{encLabels.build}}</button>
      <p class="hint">{{encLabels.hint}}</p>
    </section>
  </div>

  <!-- Modal-style generating overlay -->
  <div class="generator-overlay hidden" data-generator-overlay>
    <div class="generator-overlay-content">
      <div class="gen-spinner"></div>
      <div class="gen-title" data-gen-title>Generating NPC…</div>
      <div class="gen-status" data-gen-status>{{genSteps.contact}}</div>
      <div class="gen-progress"><div class="bar" data-gen-bar style="width: 5%;"></div></div>
      <div class="gen-steps">
        <div data-step="contact" class="step">{{genSteps.contact}}</div>
        <div data-step="resolve" class="step">{{genSteps.resolve}}</div>
        <div data-step="create" class="step">{{genSteps.create}}</div>
        <div data-step="finalize" class="step">{{genSteps.finalize}}</div>
      </div>
      <div class="gen-hint">{{genSteps.hint}}</div>
    </div>
  </div>
</form>
